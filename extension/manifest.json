{
  "manifest_version": 3,
  "name": "Reframe API",
  "version": "1.0",
  "description": "Make news accessible, unbiased, and generationally relatable.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.newsapi.org/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Reframe"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "popup.html",
        "popup.css",
        "popup.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}