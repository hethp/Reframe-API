{
  "manifest_version": 3,
  "name": "Reframe API",
  "version": "1.0",
  "description": "Make news accessible, unbiased, and generationally relatable.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.newsapi.org/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reframe"
  },
  "background": {
    "service_worker": "background.js"
  }
}
